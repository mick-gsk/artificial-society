{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Bash(/Users/moritzbecker/projekt/venv/bin/python *)",
      "Bash(/Users/moritzbecker/projekt/venv/bin/pytest *)",
      "Bash(/Users/moritzbecker/projekt/venv/bin/ruff *)",
      "Bash(python -m pytest *)",
      "Bash(pytest *)",
      "Bash(ruff *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git add *)"
    ],
    "deny": [
      "Bash(git push *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "statusMessage": "ruff (lint+format)",
            "command": "jq -r '.tool_input.file_path // .tool_response.filePath // empty' | { read -r f; case \"$f\" in *.py) /Users/moritzbecker/projekt/venv/bin/ruff check --fix \"$f\" >/dev/null 2>&1; /Users/moritzbecker/projekt/venv/bin/ruff format \"$f\" >/dev/null 2>&1 ;; esac; } 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
